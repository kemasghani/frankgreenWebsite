<div id="wa-popup-overlay" class="wa-popup-overlay hidden">
  <div class="wa-popup">

    <button id="wa-popup-close" class="wa-popup-close">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
        <path d="M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        <path d="M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- LEFT -->
    <div class="wa-popup-left">

      <h2>
        {{ section.settings.heading }}
      </h2>

      <p>
        {{ section.settings.description }}
      </p>

      <input
        type="text"
        id="wa-name"
        placeholder="{{ section.settings.name_placeholder }}"
      />

      <button id="wa-submit">
        {{ section.settings.button_text }}
      </button>

      <small>
        {{ section.settings.disclaimer_text }}
      </small>

    </div>

    <!-- RIGHT -->
    <div class="wa-popup-right">

      <picture>

        {% if section.settings.popup_image_mobile != blank %}
          <source
            media="(max-width: 768px)"
            srcset="{{ section.settings.popup_image_mobile | image_url: width: 800 }}"
          >
        {% endif %}

        {{
          section.settings.popup_image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 1200',
            alt: 'Popup Image',
            class: 'wa-popup-image'
        }}

      </picture>

    </div>

  </div>
</div>

<style>
.wa-popup-overlay{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.35);
  display:flex;
  justify-content:center;
  align-items:center;
  z-index:99999;
  opacity:1;
  visibility:visible;
  transition:opacity .35s ease, visibility .35s ease;
}

.wa-popup-overlay.hidden{
  opacity:0;
  visibility:hidden;
  pointer-events:none;
}

.wa-popup{
  width:980px;
  max-width:92%;
  background:#fff;
  border-radius:28px;
  overflow:hidden;
  display:grid;
  grid-template-columns:1fr 1fr;
  position:relative;
  transform:translateY(0) scale(1);
  transition:transform .35s ease;
}

.wa-popup-overlay.hidden .wa-popup{
  transform:translateY(20px) scale(.96);
}

.wa-popup-overlay small{
  font-size:12px;
}

.wa-popup-left{
  padding:70px 55px;
  display:flex;
  flex-direction:column;
  justify-content:center;
}

.wa-popup-left h2{
  font-size:52px;
  line-height:.95;
  font-weight:800;
  letter-spacing:-1px;
  margin:0 0 28px;
  color:#000;
}

.wa-popup-left p{
  font-size:19px;
  line-height:1.5;
  color:#333;
  margin:0 0 28px;
}

#wa-name{
  width:100%;
  height:60px;
  border:2px solid #000;
  border-radius:999px;
  padding:0 24px;
  font-size:17px;
  outline:none;
  margin-bottom:22px;
  transition:.2s ease;
  background:#fff;
}

#wa-name:focus{
  border-color:#4ea042;
}

#wa-submit{
  width:100%;
  height:62px;
  border:none;
  border-radius:999px;
  background:#4b9b41;
  color:#fff;
  font-size:17px;
  font-weight:700;
  letter-spacing:2px;
  cursor:pointer;
  transition:.25s ease;
}

#wa-submit:hover{
  transform:translateY(-1px);
  background:#43893a;
}

.wa-popup-left small{
  margin-top:22px;
  line-height:1.6;
  color:#777;
  font-size:12px;
}

.wa-popup-right{
  background:#f3f0f8;
}

.wa-popup-right picture,
.wa-popup-right img{
  width:100%;
  height:100%;
  display:block;
}

.wa-popup-right img{
  object-fit:cover;
}

.wa-popup-close{
  position:absolute;
  top:20px;
  right:20px;
  width:44px;
  height:44px;
  border:none;
  border-radius:999px;
  background:rgba(255,255,255,.9);
  backdrop-filter:blur(10px);
  display:flex;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  z-index:10;
  transition:.2s ease;
  color:#000;
  box-shadow:0 4px 18px rgba(0,0,0,.08);
}

.wa-popup-close:hover{
  transform:rotate(90deg);
  background:#fff;
}

@media(max-width:768px){

  .wa-popup{
    display:flex;
    flex-direction:column;
    max-height:90vh;
    overflow:auto;
  }

  .wa-popup-right{
    order:-1;
    height:220px;
  }

  .wa-popup-left{
    padding:35px 24px 28px;
  }

  .wa-popup-left h2{
    font-size:34px;
  }

  .wa-popup-left p{
    font-size:16px;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const overlay = document.getElementById("wa-popup-overlay");
  const closeBtn = document.getElementById("wa-popup-close");
  const submitBtn = document.getElementById("wa-submit");

  const alreadyShown = localStorage.getItem("wa_popup_shown");

  if(!alreadyShown){
    setTimeout(() => {
      overlay.classList.remove("hidden");
    }, 1200);
  }

  function closePopup(){
    overlay.classList.add("hidden");
    localStorage.setItem("wa_popup_shown", "true");
  }

  closeBtn.addEventListener("click", closePopup);

  overlay.addEventListener("click", (e) => {
    if(e.target === overlay){
      closePopup();
    }
  });

  submitBtn.addEventListener("click", () => {

    const name = document
      .getElementById("wa-name")
      .value
      .trim();

    if(!name){
      alert("Masukkan nama dulu");
      return;
    }

    const phone = "62819883326";

    const message =
      `Halo, saya ${name}, ingin bergabung`;

    const waUrl =
      `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;

    window.open(waUrl, "_blank");
  });

});
</script>

{% schema %}
{
  "name": "Join Popup WA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BECOME A FRANK FRIEND"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Join frank green Indonesia membership and get access to exclusive benefits, referral rewards, and the latest updates from us."
    },
    {
      "type": "text",
      "id": "name_placeholder",
      "label": "Name Placeholder",
      "default": "Nama"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "SIGN UP NOW"
    },
    {
      "type": "textarea",
      "id": "disclaimer_text",
      "label": "Disclaimer Text",
      "default": "By joining frank green Indonesia membership, you agree to receive promotional and marketing updates from us via email and WhatsApp. You may withdraw your consent at any time by unsubscribing from our emails or contacting frank green Indonesia’s official hotline."
    },
    {
      "type": "image_picker",
      "id": "popup_image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "popup_image_mobile",
      "label": "Mobile Image"
    }
  ],
  "presets": [
    {
      "name": "Join Popup WA"
    }
  ]
}
{% endschema %}